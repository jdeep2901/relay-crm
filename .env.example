# Relay connects to the same Supabase project as the sales-reporting dashboard,
# but reads/writes only the isolated `relay` schema. Data is authenticated-only:
# the anon key below is safe to ship in the client bundle because RLS blocks anon
# from every relay table — nothing is readable until a user logs in.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
